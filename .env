AIRFLOW_VERSION=3.2.0
PYTHON_VERSION=3.12

NETWORK_NAME=open-source-data-stack

DOCKER_IMAGE_KEYDB=eqalpha/keydb:x86_64_v6.3.4
DOCKER_IMAGE_AIRFLOW=apache/airflow:${AIRFLOW_VERSION:-latest}-python${PYTHON_VERSION:-3.12}
DOCKER_IMAGE_NGINX=nginx:1.30.2
DOCKER_IMAGE_POSTGRES=postgres:18
DOCKER_IMAGE_PYTHON=python:${PYTHON_VERSION:-3.12}-slim
DOCKER_IMAGE_VAULT=hashicorp/vault:2.0
DOCKER_IMAGE_SUPERSET=apache/superset:6.1.0

AIRFLOW_UID=1000
AIRFLOW_GID=1000
AIRFLOW_PROJ_DIR=./airflow/
AIRFLOW_IMAGE_NAME=custom-airflow:${AIRFLOW_VERSION:-latest}

SUPERSET_COMPOSE_PROJECT_NAME=superset

SUPERSET_DATABASE_DB=superset
SUPERSET_DATABASE_HOST=postgres-superset
SUPERSET_DATABASE_PASSWORD=superset
SUPERSET_DATABASE_USER=superset

# database engine specific environment variables
# change the below if you prefers another database engine
#DATABASE_PORT=5432
#DATABASE_DIALECT=postgresql
#POSTGRES_DB=superset
#POSTGRES_USER=superset
#POSTGRES_PASSWORD=superset
#MYSQL_DATABASE=superset
#MYSQL_USER=superset
#MYSQL_PASSWORD=superset
#MYSQL_RANDOM_ROOT_PASSWORD=yes

# Add the mapped in /app/pythonpath_docker which allows devs to override stuff
PYTHONPATH=/app/pythonpath:/app/docker/pythonpath_dev

FLASK_ENV=production
SUPERSET_ENV=production
SUPERSET_LOAD_EXAMPLES=no
CYPRESS_CONFIG=false
SUPERSET_PORT=8088
